TIDECHECK_API_KEY=tc_live_your_key_here

# Resend email verification.
# Create a Resend API key, verify your sending domain, then copy these into
# apps/api_fastapi/.env. Do not commit real keys.
RESEND_API_KEY=re_your_key_here
AUTH_EMAIL_FROM="Tydes <verify@send.tydes.io>"
APP_NAME=Tydes

# Production deploy config. Keep localhost values for local development.
PUBLIC_BACKEND_URL=http://127.0.0.1:8000
ALLOWED_ORIGINS=*
TYDES_DATA_DIR=./data
